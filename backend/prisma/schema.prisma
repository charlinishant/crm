// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  
}

model Project{
  id Int @id @default(autoincrement())
  name String
  description String? @db.Text
  reraProjectId Int?
  sales String?
  preSales String?
  projectType String
  possession Boolean @default(false)
  address String? @db.Text
  street String? 
  locality String?
  city String?
  state String?
  country String?
  zip String?
  longitude String?
  latitude String?
  inventory Boolean @default(false)
  noOfTowers Int @default(0)
  createdAt DateTime @default(now())
  integratedPortals String @default("")
  active Boolean @default(true)
}

enum Role{
  ADMIN
  MANAGER
  SALESPERSON
}
model User{
  id Int @id @default(autoincrement())
  username String @unique
  email String @unique
  password String
  firstName String?
  lastName  String?
  role Role
  
}

enum ContactType{
  OFFICE
  PERSONAL
}

enum Type{
  MEETINGROOMS
  DESKS
  PRIVATEOFFICES
  CABINS
}

enum Gender{
  MALE
  FEMALE
}

enum AddressType{
  HOME
  OFFICE
}

enum Status{
  BOOKED
  FRESH_LEAD
  LOST
  NP
  PROSPECT
  REGISTERED
  UNQUALIFIED
}
model Lead{
  id Int @id @default(autoincrement())
  salutation String?
  firstName String?
  lastName  String?
  emails Json?
  phones Json?
  status Status?
  timeZone String?
  tags String?
  interestedProjects String?
  team String?
  channelPartner String?
  conductSiteVisit String?
  conductSiteDate DateTime?
  leadAddress LeadAddress[]
  companyName String?
  type Type?
  carpetArea String?
  seats Int
  tenure Float
  gender Gender?
  occupations String?
  age Int?
  birthday DateTime?
  maritalStatus Boolean?
  anniversary DateTime?
  industry String
  personalAddress PersonalAddress[]
  url Json?
  education Json?
  companyTitle Json?
  income Json?
  basiComment String @db.Text
  purpose Json?
  nri Boolean @default(false)  
  budejetMin Int? @default(0)
  budejetMax Int? @default(0)
  professionMin String?
  professionMax String?
  area String?
  fundingSouurce String?
  propertyType String?
  configration String?
  budget String?
  bathroomPreferences String?
  furnishing String?
  facing String?
  locationPreferences String?
  requirementComment String @db.Text

}

model LeadAddress{
  id Int @id @default(autoincrement())
  address String?
  street String?
  city String?
  state String?
  country String?
  zip String?
  leadId Int 
  lead Lead @relation(fields: [leadId],references: [id])
}

model PersonalAddress{
  id Int @id @default(autoincrement())
  type AddressType?
  address String?
  street String?
  city String?
  state String?
  country String?
  zip String?
  leadId Int 
  lead Lead @relation(fields: [leadId],references: [id])
}


model LeadNote {
  id Int @id @default(autoincrement())
  leadId Int
  note String @db.Text
  owner String?
  createdAt DateTime @default(now())
}
