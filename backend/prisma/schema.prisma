// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  
}

model Project{
  id Int @id @default(autoincrement())
  name String
  description String? @db.Text
  reraProjectId Int?
  salesId Int?
  projectType String
  possession Boolean @default(false)
  address String? @db.Text
  street String? 
  locality String?
  city String?
  state String?
  country String?
  zip String?
  longitude String?
  latitude String?
  inventory Boolean @default(false)
  noOfTowers Int @default(0)
  createdAt DateTime @default(now())
  integratedPortals String @default("")
  active Boolean @default(true)
  tower Tower[] @relation("Project")
  floor FloorPlan[] @relation("Project")
  unit Unit[] @relation("Project")
}

model Tower{
  id Int @id @default(autoincrement())
  name String 
  projectId Int
  project Project @relation("Project",  fields: [projectId], references: [id])
  totalFloor Int? @default(0)
  reraTowerId String?
  floors FloorPlan[] @relation("Tower")
  units Unit[] @relation("Tower")
}

model FloorPlan{
  id Int @id @default(autoincrement())
  name String
  projectId Int?
  project Project? @relation("Project",  fields: [projectId], references: [id])
  towerId Int?
  tower Tower? @relation("Tower",  fields: [towerId], references: [id])
  type String?
  category String?
  bedrooms Int?
  bathrooms Int?

  // Area
  measure String?
  carpet Float?
  saleable Float?
  loading Float?
  coverArea Float?
  terraceArea Float?

  //costing
  baseRate Float?

  basePrice Float?

  units Unit[] @relation("Floor")
}

model UnitModel{
  id Int @id @default(autoincrement())
  name String 
  floor Int?
  unitIndex Int?
  baseRate Float? 
  basePrice Float?
  propertyPurpose String? 
  unitId Int
  unit Unit @relation(fields: [unitId], references: [id])
}


model Unit{
  id Int @id @default(autoincrement())
  unitList UnitModel[]
  projectId Int?
  project Project? @relation("Project",  fields: [projectId], references: [id])
  towerId Int?
  tower Tower? @relation("Tower",  fields: [towerId], references: [id])
  floorId Int?
  floor FloorPlan? @relation("Floor",  fields: [floorId], references: [id])
  type String?
  category String?
  bedrooms Int? 
  bathrooms Int?

  measure String?
  carpet Float?
  saleable Float?
  loading Float?
  description String @db.Text
}   

enum Role{
  PRE_SALES
  SALES
  POST_SALES
  MANAGER
  ADMIN
  AGENCY_USER
  AGENT
}

enum Department{
  PRE_SALES
  SALES
  POST_SALES
}
model User{
  id Int @id @default(autoincrement())
  isActive Boolean @default(true)

  //personal details
  username String? @unique
  email String @unique
  password String?
  firstName String?
  lastName  String?
  phone String @unique @db.Char(10)
  secondaryPhone String? @db.Char(10)
  timeZone String?

  //custom fields
  linkedUrl String? 
  description String?

  // Professional details
  role Role?
  department Department?

  defaultRouting Boolean? @default(false)
  defaultRoutingRule Boolean? @default(false)
  autoRoster Boolean? @default(false)
  teamId Int?
  team Team? @relation("Team", fields: [teamId], references: [id])
  // Other settings
  pushNotification Boolean? @default(false)
  gpsTracking Boolean? @default(false)
  
}

enum ContactType{
  OFFICE
  PERSONAL
}

enum Type{
  MEETINGROOMS
  DESKS
  PRIVATEOFFICES
  CABINS
}

enum Gender{
  MALE
  FEMALE
}

enum AddressType{
  HOME
  OFFICE
}

enum Status{
  Booked
  Fresh_Lead
  Lost
  NP
  Prospect
  Registered
  Unqualified
}
model Lead{
  id Int @id @default(autoincrement())
  salutation String?
  firstName String?
  lastName  String?
  emails Json?
  phones Json?
  status Status?
  timeZone String?
  tags String?
  interestedProjects String?
  team String?
  channelPartner String?
  conductSiteVisit String?
  conductSiteDate DateTime?
  leadAddress LeadAddress[]
  companyName String?
  type Type?
  carpetArea String?
  seats Int
  tenure Float
  gender Gender?
  occupations String?
  age Int?
  birthday DateTime?
  maritalStatus Boolean?
  anniversary DateTime?
  industry String
  personalAddress PersonalAddress[]
  url Json?
  education Json?
  companyTitle Json?
  income Json?
  basiComment String @db.Text
  purpose Json?
  nri Boolean @default(false)  
  budejetMin Int? @default(0)
  budejetMax Int? @default(0)
  professionMin String?
  professionMax String?
  area String?
  fundingSouurce String?
  propertyType String?
  configration String?
  budget String?
  bathroomPreferences String?
  furnishing String?
  facing String?
  locationPreferences String?
  requirementComment String @db.Text

}

model LeadAddress{
  id Int @id @default(autoincrement())
  address String?
  street String?
  city String?
  state String?
  country String?
  zip String?
  leadId Int 
  lead Lead @relation(fields: [leadId],references: [id])
}

model PersonalAddress{
  id Int @id @default(autoincrement())
  type AddressType?
  address String?
  street String?
  city String?
  state String?
  country String?
  zip String?
  leadId Int 
  lead Lead @relation(fields: [leadId],references: [id])
}


model LeadNote {
  id Int @id @default(autoincrement())
  leadId Int
  note String @db.Text
  owner String?
  createdAt DateTime @default(now())
}


model Team{
  id Int @id @default(autoincrement())
  name String
  location String?
  parentId Int?
  parent Team? @relation("ParentTeam", fields: [parentId], references: [id])
  teams Team[] @relation("ParentTeam")
  users User[] @relation("Team") 
}
