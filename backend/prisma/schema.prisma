// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  
}

model Project{
  id Int @id @default(autoincrement())
  name String
  description String? @db.Text
  reraProjectId Int?
  sales String?
  preSales String?
  projectType String
  possession Boolean @default(false)
  address String? @db.Text
  street String? 
  locality String?
  city String?
  state String?
  country String?
  zip String?
  longitude String?
  latitude String?
  inventory Boolean @default(false)
  noOfTowers Int @default(0)
  createdAt DateTime @default(now())
  integratedPortals String @default("")
  active Boolean @default(true)
}

enum Role{
  ADMIN
  MANAGER
  SALESPERSON
}
model User{
  id Int @id @default(autoincrement())
  email String @unique
  password String
  firstName String?
  lastName  String?
  role Role
  
}

enum ContactType{
  OFFICE
  PERSONAL
}

enum Type{
  MEETINGROOMS
  DESKS
  PRIVATEOFFICES
  CABINS
}

enum Gender{
  MALE
  FEMALE
}

enum AddressType{
  HOME
  OFFICE
}
model Lead{
  id Int @id @default(autoincrement())
  salutation String?
  firstName String?
  lastName  String?
  emailType ContactType?
  email String?
  phoneType ContactType
  phone String?
  timeZone String?
  tags String?
  interestedProjects String?
  team String?
  channelPartner String?
  conductSiteVisit String?
  conductSiteDate DateTime?
  leadAddress String?
  street String?
  city String?
  state String?
  country String?
  zip String?
  companyName String?
  type Type?
  carpetArea String?
  seats Int
  tenure Float
  gender Gender?
  occupations String?
  age Int?
  birthday DateTime?
  maritalStatus Boolean?
  aniversary DateTime
  industry String
  addressType AddressType?
  address String?

}

model LeadNote {
  id Int @id @default(autoincrement())
  leadId Int
  note String @db.Text
  owner String?
  createdAt DateTime @default(now())
}
